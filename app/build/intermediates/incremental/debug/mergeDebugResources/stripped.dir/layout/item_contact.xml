<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/md_surface"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="1dp"
    app:rippleColor="@color/md_primary"
    app:strokeColor="@color/stroke_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/padding_card">

        <FrameLayout
            android:layout_width="@dimen/avatar_size"
            android:layout_height="@dimen/avatar_size">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_placeholder"
                android:contentDescription="@null"
                android:padding="10dp"
                android:src="@drawable/ic_person"
                app:tint="@color/md_on_surface_variant" />

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="@dimen/status_dot"
                android:layout_height="@dimen/status_dot"
                android:layout_gravity="bottom|end"
                android:background="@drawable/status_indicator" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUsername"
                style="@style/TextAppearance.Messenger.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                tools:text="user1" />

            <TextView
                android:id="@+id/tvStatus"
                style="@style/TextAppearance.Messenger.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxs"
                tools:text="В сети" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
