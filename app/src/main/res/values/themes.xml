<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Messenger" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorPrimaryContainer">@color/md_surface_variant</item>
        <item name="colorOnPrimaryContainer">@color/md_on_surface</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorOnBackground">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_divider</item>
        <item name="android:statusBarColor">@color/md_background</item>
        <item name="android:navigationBarColor">@color/md_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="materialCardViewStyle">@style/Widget.Messenger.Card</item>
    </style>

    <style name="Widget.Messenger.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardBackgroundColor">@color/md_surface</item>
    </style>
</resources>
