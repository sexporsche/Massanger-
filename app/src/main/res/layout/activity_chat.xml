<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_surface"
        app:elevation="2dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarChat"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:titleCentered="false"
            app:titleEnabled="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivToolbarAvatar"
                    android:layout_width="@dimen/avatar_sm"
                    android:layout_height="@dimen/avatar_sm"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/md_on_surface_variant" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvToolbarTitle"
                        style="@style/TextAppearance.Messenger.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        tools:text="User" />

                    <TextView
                        android:id="@+id/tvToolbarStatus"
                        style="@style/TextAppearance.Messenger.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="В сети" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toTopOf="@+id/inputBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:listitem="@layout/item_message_received" />

        <TextView
            android:id="@+id/tvEmptyChat"
            style="@style/TextAppearance.Messenger.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/empty_chat"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/rvMessages"
            app:layout_constraintEnd_toEndOf="@id/rvMessages"
            app:layout_constraintStart_toStartOf="@id/rvMessages"
            app:layout_constraintTop_toTopOf="@id/rvMessages" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/inputBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/padding_screen"
            android:layout_marginVertical="12dp"
            app:cardBackgroundColor="@color/md_surface"
            app:cardCornerRadius="@dimen/input_radius"
            app:cardElevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@color/stroke_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingVertical="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAttach"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/attach"
                    app:icon="@drawable/ic_attach"
                    app:iconTint="@color/md_on_surface_variant" />

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_message"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="6"
                    android:minHeight="48dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/md_on_surface"
                    android:textColorHint="@color/md_on_surface_variant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSend"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/send"
                    app:backgroundTint="@color/md_primary"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/md_on_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
